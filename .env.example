# Market Data (Get free key from twelvedata.com)
TWELVE_DATA_API_KEY=your_twelvedata_api_key_here

# Discord (USE THIS INSTEAD OF TELEGRAM)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Trading Config
WATCHLIST=XAU/USD,EUR/USD
MIN_CONFIDENCE=60
MIN_CONFLUENCE=3
# MT5 Auto-Execute (Optional - set to true to enable)
MT5_ENABLED=false
MT5_SERVER_URL=http://localhost:5000
DEBUG_MODE=true
TIMEFRAME=5min
API_DAILY_LIMIT=750
SIGNAL_COOLDOWN_MINS=15